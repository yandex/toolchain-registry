@@ -55,6 +55,16 @@ using llvm::MemoryBuffer;
 STATISTIC(MaxUsedSLocBytes, "Maximum number of bytes used by source locations "
                             "(both loaded and local).");

+// Like FileManager's directory/file counters: keep this as a TrackingStatistic
+// so release builds still record values when the frontend calls
+// llvm::EnableStatistics() (e.g. -save-stats). Plain STATISTIC is a no-op when
+// LLVM_ENABLE_STATS is off.
+ALWAYS_ENABLED_STATISTIC(
+    NumFileBytesInTranslationUnit,
+    "Approximate total bytes of source file content in the current translation "
+    "unit (ContentCache::getSize() for each new FileID; the same file included "
+    "in multiple places is counted for each #include).");
+
