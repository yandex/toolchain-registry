+        if (N->isOneOf(tok::l_brace, TT_TemplateOpener)) {
+            return true;
+        }
+    }
+
+    if (L == 'T' || L == 'N') {
+        if (N->TokenText == "::") {
+            return possibleClassName(N->Next);
+        }
+    }
+
+    return false;
+}
