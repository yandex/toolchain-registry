   static u8 llvm_fullpath[PATH_MAX];
   u8       *compiler_path = NULL;

+#ifdef AFL_STATIC_LLVM_PASS
+  /* When built as a static toolchain, resolve the companion clang binary
+     relative to our own executable location via /proc/self/exe.  This
+     makes the toolchain relocatable – no hard-coded install prefix. */
+  static u8 self_dir[PATH_MAX];
+  static int self_dir_resolved = 0;
+  if (!self_dir_resolved) {
+    ssize_t len = readlink("/proc/self/exe", self_dir, sizeof(self_dir) - 1);
+    if (len > 0) {
+      self_dir[len] = 0;
+      char *sl = strrchr(self_dir, '/');
+      if (sl) *sl = 0;
+      self_dir_resolved = 1;
+    }
+  }
+#define RESOLVE_SIBLING(name) \
+  do { \
+    if (self_dir_resolved) \
+      snprintf(llvm_fullpath, sizeof(llvm_fullpath), "%s/" name, self_dir); \
+    else \
+      snprintf(llvm_fullpath, sizeof(llvm_fullpath), name); \
+  } while(0)
+#endif
+
